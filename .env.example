# Browser-exposed backend base URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional server-only backend URL for Next API routes
# If omitted, app/api routes fallback to NEXT_PUBLIC_API_URL
API_URL=http://localhost:8000

# Kakao Maps JavaScript SDK key (client)
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_javascript_key

# Kakao Local REST API key (server route for AI location tags)
KAKAO_REST_API_KEY=your_kakao_rest_api_key
